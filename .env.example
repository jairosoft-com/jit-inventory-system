# ============================================
# JIT Inventory & Equipment Management System
# Environment Variables Example
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control

# ── Database ──────────────────────────────────
# Change "localhost" to the shared database host's IP if sharing a database machine
# ?connection_limit=5 prevents Prisma from exceeding the Supabase session-mode pool cap (15)
DATABASE_URL=postgresql://jit_user:jit_password@localhost:5432/jit_db?connection_limit=5

# ── PostgreSQL (Docker Compose) ───────────────
POSTGRES_USER=jit_user
POSTGRES_PASSWORD=jit_password
POSTGRES_DB=jit_db

# ── JWT Authentication ────────────────────────
JWT_ACCESS_SECRET=changeme-generate-a-secure-key-here
JWT_REFRESH_SECRET=changeme-generate-a-secure-key-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Encryption (pgcrypto) ─────────────────────
# Used to encrypt license keys at rest (minimum 32 characters)
ENCRYPTION_KEY=changeme-min-32-chars-key-length

# ── MinIO (S3-compatible storage) ─────────────
# Change "localhost" to the MinIO host's IP if sharing
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=changeme-access-key
S3_SECRET_KEY=changeme-secret-key
S3_BUCKET=jit-images

# ── Email (MailDev) ───────────────────────────
# Change "localhost" to the MailDev host's IP if sharing
SMTP_HOST=localhost
SMTP_PORT=1025

# ── Backend ───────────────────────────────────
BACKEND_PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Frontend ──────────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ── Rate Limiting (per IP, 15-minute sliding window) ─
RATE_LIMIT_GLOBAL=600
RATE_LIMIT_MUTATIVE=120
RATE_LIMIT_AUTH=15
RATE_LIMIT_HEAVY=30

# ── Redis (Caching & Rate Limiting) ──────────
# Change "localhost" to the Redis host's IP if sharing
REDIS_URL=redis://localhost:6379

