# ── AUTHENTICATION ───────────────────────────────────────────────────────────

### Login (Get Token)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "sam@jitims.com",
  "password": "admin123"
}


# ── EQUIPMENT CRUD ───────────────────────────────────────────────────────────

### Create Equipment
POST {{baseUrl}}/equipment
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "itemName": "Dell XPS 15",
  "assetId": "ASSET-1001",
  "serialNumber": "SN-987654321",
  "categoryId": 115,
  "condition": "NEW",
  "status": "AVAILABLE",
  "images": [
    {
      "url": "https://example.com/images/laptop1.png",
      "label": "Front View",
      "isPrimary": true
    }
  ]
}

### Get All Equipment
GET {{baseUrl}}/equipment
Authorization: Bearer {{token}}

### Get Single Equipment (Change '1' to your actual Equipment ID)
GET {{baseUrl}}/equipment/1
Authorization: Bearer {{token}}

### Update Equipment
PATCH {{baseUrl}}/equipment/2
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serialNumber": "SN-UPDATED-001",
  "condition": "GOOD"
}

### Delete Equipment (Soft Delete)
DELETE {{baseUrl}}/equipment/1
Authorization: Bearer {{token}}


# ── EQUIPMENT IMAGES ─────────────────────────────────────────────────────────

### Add New Image to Equipment
POST {{baseUrl}}/equipment/1/images
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "url": "https://example.com/images/laptop-side.png",
  "label": "Side View",
  "isPrimary": false
}

### Update Image 
PATCH {{baseUrl}}/equipment/2/images/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "label": "Updated Side View",
  "isPrimary": true
}

### Delete Image (Soft Delete)
DELETE {{baseUrl}}/equipment/1/images/2
Authorization: Bearer {{token}}